{
    "manifest_version": 3,
    "name": "Flashcard Creator",
    "version": "1.0",
    "description": "Create flashcards from selected text",
  
    "action": {
      "default_popup": "popup.html"
    },
  
    "background": {
      "type": "module"
    },
  
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"],
        "run_at": "document_idle"
      }
    ],
  
    "web_accessible_resources": [
      {
        "resources": ["popup.html", "popup.js", "popup.css"],
        "matches": ["<all_urls>"]
      }
    ],
  
    "permissions": [
      "activeTab"
    ],
    "host_permissions": ["<all_urls>"]
  }
  